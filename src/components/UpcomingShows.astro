---
const shows = [
	{
		title: "La Gaille : Entre rire et réalité",
		date: "14 Décembre 2025",
		location: "Boui Boui Café Comique, Lyon",
		description: "Diplôme d'ingénieur en poche, il se lance dans la vie active, mais quelque chose cloche. Toujours à se poser mille questions, il décide de troquer son clavier contre un micro et de monter sur scène pour en parler.",
		url: "https://www.billetreduc.com/spectacle/la-gaille-entre-rire-et-realite-384355"
	},
	{
		title: "La Gaille : Entre rire et réalité",
		date: "21 Décembre 2025",
		location: "Boui Boui Café Comique, Lyon",
		description: "Diplôme d'ingénieur en poche, il se lance dans la vie active, mais quelque chose cloche. Toujours à se poser mille questions, il décide de troquer son clavier contre un micro et de monter sur scène pour en parler.",
		url: "https://www.billetreduc.com/spectacle/la-gaille-entre-rire-et-realite-384355"
	},
	{
		title: "La Gaille : Entre rire et réalité",
		date: "28 Décembre 2025",
		location: "Boui Boui Café Comique, Lyon",
		description: "Diplôme d'ingénieur en poche, il se lance dans la vie active, mais quelque chose cloche. Toujours à se poser mille questions, il décide de troquer son clavier contre un micro et de monter sur scène pour en parler.",
		url: "https://www.billetreduc.com/spectacle/la-gaille-entre-rire-et-realite-384355"
	},
];
---

<section class="shows container">
	<h2>Prochaines Dates</h2>
	<div class="shows-grid">
		{shows.map(show => (
			<article class="show-card">
				<div class="date-badge">{show.date}</div>
				<h3>{show.title}</h3>
				<p class="location">{show.location}</p>
				<p class="description">{show.description}</p>
				<a href={show.url} class="btn-ticket" target="_blank" rel="noopener noreferrer">Réserver</a>
			</article>
		))}
	</div>
</section>

<style>
	.shows {
		padding: 4rem 1.5rem;
	}
	
	h2 {
		font-size: 3rem;
		margin-bottom: 3rem;
	}
	
	.shows-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}
	
	.show-card {
		background: var(--color-card-bg);
		padding: 2rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		transition: transform 0.2s, border-color 0.2s;
	}
	
	.show-card:hover {
		transform: translateY(-5px);
		border-color: var(--color-accent);
	}
	
	.date-badge {
		color: var(--color-accent);
		font-weight: 600;
		text-transform: uppercase;
		font-size: 0.9rem;
		margin-bottom: 0.5rem;
	}
	
	h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}
	
	.location {
		color: var(--color-text-muted);
		font-style: italic;
		margin-bottom: 1rem;
	}
	
	.btn-ticket {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.5rem 1.5rem;
		background: white;
		color: black;
		font-weight: 600;
		border-radius: 2rem;
		transition: background 0.2s;
	}
	
	.btn-ticket:hover {
		background: var(--color-accent);
	}
</style>
