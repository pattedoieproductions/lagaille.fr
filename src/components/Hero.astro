---
---

<section class="hero">
  <div class="hero-photo">
    <div class="hero-image">
      <img src="/photo_la_gaille_1.jpg" alt="La Gaille, humoriste stand-up" />
      <div class="hero-vignette"></div>
      <div class="hero-title">
        <h1 class="photo-title-text">La Gaille</h1>
      </div>
    </div>
    <div class="hero-content">
      <div class="hero-block">
        <p class="label">Stand-up · One-man-show</p>
        <div class="label-line"></div>
        <a href="#dates" class="btn-ghost">Voir les dates &darr;</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 68px;
  }

  /* ── Desktop : tout dans la photo ── */
  .hero-photo {
    position: relative;
    width: 100%;
    height: calc(100vh - 68px);
    min-height: 500px;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 85% 20%, rgba(0,0,0,0.35) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-title {
    position: absolute;
    bottom: 40%;
    right: 6%;
    pointer-events: none;
  }

  .hero-content {
    position: absolute;
    top: 7%;
    right: 6%;
    width: 36vw;
    max-width: 460px;
  }

  .hero-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  /* ── Styles communs ── */
  .label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .label-line {
    width: 2.5rem;
    height: 1.5px;
    background: var(--color-accent);
    margin-bottom: 1.1rem;
    opacity: 0.8;
  }

  .teaser {
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    color: rgba(255,255,255,0.9);
    line-height: 1.75;
    margin-bottom: 2rem;
    text-shadow: 0 1px 10px rgba(0,0,0,0.6);
  }

  .btn-ghost {
    display: inline-block;
    border: 1.5px solid rgba(255,255,255,0.85);
    color: rgba(255,255,255,0.9);
    background: transparent;
    padding: 0.75rem 1.8rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s;
  }

  .btn-ghost:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  .photo-title-text {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7.5rem);
    font-weight: 700;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #ffffff;
    text-shadow:
      0 2px 30px rgba(0,0,0,0.4),
      0 0 80px rgba(0,0,0,0.2);
    display: block;
    white-space: nowrap;
  }

  /* ── Mobile : photo + section contenu empilés ── */
  @media (max-width: 700px) {
    .hero-photo {
      height: auto;
      min-height: 0;
      overflow: visible;
      display: flex;
      flex-direction: column;
    }

    .hero-image {
      position: relative;
      height: 55svh;
      flex-shrink: 0;
      overflow: hidden;
    }

    .hero-image img {
      object-position: center 20%;
    }

    .hero-title {
      bottom: auto;
      top: 12%;
      right: 5%;
    }

    .photo-title-text {
      font-size: clamp(2.5rem, 12vw, 4rem);
    }

    .hero-content {
      position: static;
      width: 100%;
      max-width: 100%;
      background: var(--color-surface);
      padding: 2rem 1.5rem 2.5rem;
    }

    .hero-block {
      align-items: flex-end;
      text-align: right;
    }

    .teaser {
      font-size: 0.9rem;
      color: var(--color-muted);
      text-shadow: none;
    }

    .btn-ghost {
      border-color: var(--color-text);
      color: var(--color-text);
    }

    .btn-ghost:hover {
      background: var(--color-text);
      color: var(--color-bg);
    }
  }
</style>
