<section class="contact">
	<div class="container">
		<div class="cta-grid">
			<div class="cta-box organizers">
				<h3>Pour les Organisateurs</h3>
				<p>Vous souhaitez programmer l'un de nos artistes ou organiser un plateau ?</p>
				<a href="mailto:pattedoie.productions@gmail.com" class="btn">Booker un spectacle</a>
			</div>
			
			<div class="cta-box artists">
				<h3>Pour les Artistes</h3>
				<p>Vous pensez avoir le talent pour rejoindre l'écurie Pattedoie ?</p>
				<a href="mailto:pattedoie.productions@gmail.com" class="btn btn-outline">Envoyer une démo</a>
			</div>
		</div>
	</div>
</section>

<style>
	.contact {
		padding: 6rem 0;
		background: linear-gradient(to top, #000, #0f0f11);
	}
	
	.cta-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 3rem;
	}
	
	.cta-box {
		padding: 3rem;
		border-radius: 2rem;
		background: rgba(255, 255, 255, 0.03);
		text-align: center;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}
	
	.cta-box:hover {
		background: rgba(255, 255, 255, 0.05);
	}
	
	h3 {
		font-size: 2rem;
		margin-bottom: 1rem;
		color: white;
	}
	
	p {
		margin-bottom: 2rem;
		font-size: 1.1rem;
	}
	
	.btn {
		display: inline-block;
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 700;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	
	.btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(0,0,0,0.3);
	}
	
	.organizers .btn {
		background: var(--color-accent);
		color: #000;
	}
	
	.artists .btn {
		background: transparent;
		color: white;
		border: 2px solid white;
	}
	
	.artists .btn:hover {
		background: white;
		color: black;
	}
</style>
