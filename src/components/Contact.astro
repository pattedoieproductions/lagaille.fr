---

<section id="contact">
  <div class="container">
    <h2>Contact</h2>
    <p class="subtitle">Pour toute demande de réservation, programmation ou information.</p>

    <div class="contact-grid">

      <a href="https://www.instagram.com/la_gaille_/" target="_blank" rel="noopener" class="contact-item">
        <div class="icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
        </div>
        <div>
          <p class="contact-label">Instagram</p>
          <p class="contact-value">@la_gaille_</p>
        </div>
      </a>

    </div>

    <p class="production">Production &amp; diffusion : <strong>Pattedoie Productions</strong></p>
  </div>
</section>

<style>
  section {
    padding: var(--section-padding);
    background: var(--color-surface);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .subtitle {
    color: var(--color-muted);
    margin-bottom: 3rem;
    max-width: 48ch;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, transform 0.15s;
  }

  .contact-item:hover {
    border-color: var(--color-text);
    transform: translateY(-2px);
  }

  .icon {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
    word-break: break-word;
  }

  .production {
    font-size: 0.85rem;
    color: var(--color-muted);
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .production strong {
    color: var(--color-text);
  }

  @media (max-width: 680px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
