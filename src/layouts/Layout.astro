---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Pattedoie Productions - La nouvelle vague du stand-up français." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "favicon.png"} />
		<link rel="apple-touch-icon" href={import.meta.env.BASE_URL + "apple-touch-icon.png"} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--color-bg: #0f0f11;
		--color-text-main: #f0f0f5;
		--color-text-muted: #a0a0b0;
		--color-accent: #FFD700; /* Gold */
		--color-accent-2: #FF4500; /* OrangeRed */
		--color-card-bg: #1a1a1f;

		--font-main: 'Outfit', sans-serif;
	}
	html {
		font-family: var(--font-main);
		background: var(--color-bg);
		color: var(--color-text-main);
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
	}
	h1, h2, h3, h4 {
		margin: 0;
		line-height: 1.1;
		font-weight: 800;
	}
	p {
		line-height: 1.6;
		color: var(--color-text-muted);
	}
	a {
		color: inherit;
		text-decoration: none;
	}
	img {
		max-width: 100%;
		display: block;
	}
	
	/* Utilities */
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
</style>
